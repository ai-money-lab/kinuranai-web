# kinuranai-web 環境変数 (Vercel ダッシュボードで設定)

# ===== LINE Bot =====
# https://developers.line.biz/console/ で公式アカウント作成 → Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_OFFICIAL_URL=https://lin.ee/kinuranai

# ===== PAY.JP (Stripe代替・占いカテゴリ審査通過実績あり) =====
# https://pay.jp/ で登録 → ダッシュボード → API
PAYJP_PUBLIC_KEY=pk_live_xxxxx
PAYJP_SECRET_KEY=sk_live_xxxxx
PAYJP_WEBHOOK_SECRET=your_webhook_secret_hex
PAYJP_PLAN_MONTHLY_NEWS=plan_xxxxx_1100_jpy_monthly

# ===== Anthropic (Claude API) =====
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-5

# ===== Internal =====
INTERNAL_API_SECRET=random_hex_for_internal_api_calls
PUBLIC_BASE_URL=https://kinuranai.vercel.app
